{
  "version": 2,
  "builds": [
    {
      "src": "tradd_vercel/public/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "tradd_vercel/public/admin.html",
      "use": "@vercel/static"
    },
    {
      "src": "tradd_vercel/api/health.js",
      "use": "@vercel/node"
    },
    {
      "src": "tradd_vercel/api/auth/signin.js",
      "use": "@vercel/node"
    },
    {
      "src": "tradd_vercel/api/auth/signup.js",
      "use": "@vercel/node"
    },
    {
      "src": "tradd_vercel/api/auth/me.js",
      "use": "@vercel/node"
    },
    {
      "src": "tradd_vercel/api/auth/logout.js",
      "use": "@vercel/node"
    },
    {
      "src": "tradd_vercel/api/auth/google.js",
      "use": "@vercel/node"
    },
    {
      "src": "tradd_vercel/api/blog/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "tradd_vercel/api/blog/[slug].js",
      "use": "@vercel/node"
    },
    {
      "src": "tradd_vercel/api/trades/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "tradd_vercel/api/trades/[id].js",
      "use": "@vercel/node"
    },
    {
      "src": "tradd_vercel/api/user/profile.js",
      "use": "@vercel/node"
    },
    {
      "src": "tradd_vercel/api/config/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "tradd_vercel/api/flags/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "tradd_vercel/api/announcements/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "tradd_vercel/api/admin/users.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "tradd_vercel/api/health.js"
    },
    {
      "src": "/api/auth/signin",
      "dest": "tradd_vercel/api/auth/signin.js"
    },
    {
      "src": "/api/auth/signup",
      "dest": "tradd_vercel/api/auth/signup.js"
    },
    {
      "src": "/api/auth/me",
      "dest": "tradd_vercel/api/auth/me.js"
    },
    {
      "src": "/api/auth/logout",
      "dest": "tradd_vercel/api/auth/logout.js"
    },
    {
      "src": "/api/auth/google",
      "dest": "tradd_vercel/api/auth/google.js"
    },
    {
      "src": "/api/blog/(.+)",
      "dest": "tradd_vercel/api/blog/[slug].js"
    },
    {
      "src": "/api/blog",
      "dest": "tradd_vercel/api/blog/index.js"
    },
    {
      "src": "/api/trades/(.+)",
      "dest": "tradd_vercel/api/trades/[id].js"
    },
    {
      "src": "/api/trades",
      "dest": "tradd_vercel/api/trades/index.js"
    },
    {
      "src": "/api/user/profile",
      "dest": "tradd_vercel/api/user/profile.js"
    },
    {
      "src": "/api/config",
      "dest": "tradd_vercel/api/config/index.js"
    },
    {
      "src": "/api/flags",
      "dest": "tradd_vercel/api/flags/index.js"
    },
    {
      "src": "/api/announcements",
      "dest": "tradd_vercel/api/announcements/index.js"
    },
    {
      "src": "/api/admin/users",
      "dest": "tradd_vercel/api/admin/users.js"
    },
    {
      "src": "/admin",
      "dest": "tradd_vercel/public/admin.html"
    },
    {
      "src": "/admin.html",
      "dest": "tradd_vercel/public/admin.html"
    },
    {
      "src": "/(.*)",
      "dest": "tradd_vercel/public/index.html"
    }
  ]
}